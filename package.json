{
  "name": "rdtect-os",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": ["apps/*", "packages/*", "plugins/*", "labs/*"],
  "scripts": {
    "dev": "vite dev --host",
    "dev:services": "docker compose up -d",
    "dev:full": "docker compose --profile full up",
    "dev:all": "docker compose --profile all up",
    "dev:python": "docker compose up python-backend",
    "dev:excalidraw": "bun run --filter @desktop-os/excalidraw-remote preview",
    "build": "vite build",
    "build:docker": "docker compose -f docker-compose.prod.yml build",
    "build:excalidraw": "bun run --filter @desktop-os/excalidraw-remote build",
    "build:all": "bun run build && bun run build:excalidraw",
    "preview": "vite preview",
    "start": "docker compose -f docker-compose.prod.yml up -d",
    "stop": "docker compose down",
    "stop:all": "docker compose --profile all down",
    "logs": "docker compose logs -f",
    "db:admin": "echo 'Open http://localhost:8090/_/ in your browser'",
    "db:backup": "docker compose exec pocketbase ./pocketbase backup",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .svelte-kit build node_modules/.vite"
  },
  "devDependencies": {
    "@originjs/vite-plugin-federation": "^1.4.1",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/adapter-node": "^5.5.3",
    "@sveltejs/kit": "^2.50.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/forms": "^0.5.0",
    "@types/bun": "latest",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "svelte": "^5.47.0",
    "svelte-check": "^4.3.5",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "pocketbase": "^0.26.6"
  }
}
