    "@types/bun": "latest",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "svelte": "^5.47.0",
    "svelte-check": "^4.3.5",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@desktop-os/plugin-sdk": "workspace:*",
