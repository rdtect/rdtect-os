# ============================================================
# rdtect OS Python Backend — Environment Variables
# Copy to .env and fill in values
# ============================================================

# --- AI (Required) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Cloudflare AI Gateway (Optional — enables caching + rate limiting) ---
# Format: https://gateway.ai.cloudflare.com/v1/{account_id}/rdtect-os/anthropic
CF_AI_GATEWAY_URL=
CF_ACCOUNT_ID=
CF_WORKERS_AI_API_KEY=

# --- Claude Models ---
CLAUDE_CHAT_MODEL=claude-haiku-4-5-20251001
CLAUDE_AGENT_MODEL=claude-sonnet-4-6

# --- Agent Settings ---
AGENT_MAX_ITERATIONS=10

# --- ChromaDB (Knowledge Base) ---
CHROMA_URL=https://chroma.rdtect.com
CHROMA_BEARER_TOKEN=
CHROMA_COLLECTION=obsidian_vault
RAG_TOP_K=5
RAG_MIN_SCORE=1.2

# --- VPS Monitoring ---
DOCKER_SOCKET=/var/run/docker.sock
OLLAMA_URL=http://localhost:11434

# --- CORS ---
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://rdtect.com,http://localhost:5176

