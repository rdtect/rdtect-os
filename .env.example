# ==============================================
# rdtect OS Environment Configuration
# ==============================================
# Copy this file to .env and fill in your values
# For production, set these in Coolify's environment variables section

# ----------------------------------------------
# Domain & URLs (Production)
# ----------------------------------------------
# Your domain (used by Traefik for routing)
DOMAIN=rdtect.com

# Origin URL for CORS (SvelteKit requires this in production)
ORIGIN=https://rdtect.com

# ----------------------------------------------
# Service Ports (Development Overrides)
# ----------------------------------------------
FRONTEND_PORT=3000
POCKETBASE_PORT=8090
PYTHON_BACKEND_PORT=8000
PISTON_PORT=2000

# ----------------------------------------------
# PocketBase Configuration
# ----------------------------------------------
PUBLIC_POCKETBASE_URL=https://pb.rdtect.com
PB_ENCRYPTION_KEY=

# Admin credentials (CHANGE IN PRODUCTION!)
POCKETBASE_ADMIN_EMAIL=admin@rdtect.dev
POCKETBASE_ADMIN_PASSWORD=changeme123

# Internal URL (for inter-service communication in Docker)
POCKETBASE_URL=http://pocketbase:8090

# ----------------------------------------------
# Python Backend Configuration
# ----------------------------------------------
PUBLIC_PYTHON_API_URL=https://api.rdtect.com
PUBLIC_PYTHON_BACKEND_URL=https://api.rdtect.com

# ----------------------------------------------
# OpenAI Configuration (for AI features)
# ----------------------------------------------
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ----------------------------------------------
# Piston Code Execution Engine (Optional)
# ----------------------------------------------
PUBLIC_PISTON_URL=http://localhost:2000

# ----------------------------------------------
# Database Configuration (Legacy - if using MySQL)
# ----------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=desktop_os

# ----------------------------------------------
# Storage Configuration
# ----------------------------------------------
MARKDOWN_DIR=./data/markdown

# ----------------------------------------------
# Production Settings
# ----------------------------------------------
NODE_ENV=production

# Set to 'true' if deployed behind a reverse proxy (Coolify/Traefik)
# TRUST_PROXY=true
